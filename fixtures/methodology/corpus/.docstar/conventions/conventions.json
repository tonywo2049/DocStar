{
  "version": "1",
  "namespaces": {
    "kind_namespace": {
      "需求AC": "需求池-M1",
      "非功能需求": "需求池-M1"
    },
    "req_doc": "需求池-M1.md",
    "param_registry": "需求池-M1.md",
    "task_doc_stem": "任务-M1",
    "mapping_doc_stem": "需求池-M1",
    "prefix_namespaces": {}
  },
  "def_forms": {
    "需求": "^###\\s*(R\\d+)\\b",
    "需求AC": "^-\\s*\\*\\*(R\\d+-AC\\d+)\\*\\*",
    "非功能需求": "^-\\s*\\*\\*(NFR\\d+)\\b",
    "任务": "^\\|\\s*\\*\\*(T\\d+(?:\\.\\d+)?)\\*\\*",
    "决议": "^##\\s*(§\\d+)\\b",
    "设计问题": "^\\*\\*(Q\\d+)\\s*——"
  },
  "term_forms": {
    "inplace": "\\*\\*([^*]{2,20})\\*\\*（定义：([^）]+)）",
    "glossary": "^-?\\s*\\*\\*([^*]{2,20})\\*\\*[：:](.{4,})"
  },
  "form_headers": {
    "ledger": "^\\|\\s*日期\\s*\\|(?:\\s*版本\\s*\\|)?\\s*变更\\s*\\|",
    "changelist": "^\\|\\s*项\\s*\\|\\s*(?:落点|文档与落点)\\b",
    "glossary_section": "术语表|名词解释|词汇表|glossary|前提与公共定义"
  },
  "harvest": {
    "len_range": [2, 20],
    "exclude": [
      "^\\d+$",
      "^\\d{4}-\\d{2}-\\d{2}$",
      "^[rv]\\d+(?:\\.\\d+)?$",
      "^(?:R\\d+(?:-AC\\d+)?|NFR\\d+|T\\d+(?:\\.\\d+)?|Q\\d+|M\\d+|§\\d+)$"
    ]
  },
  "doc_id_kinds": [
    ["需求AC", "(?<![A-Za-z0-9_])R\\d+-AC\\d+(?![A-Za-z0-9_])", "唯一；需求池 §B 定义，设计/任务/账本表格引用"],
    ["非功能需求", "(?<![A-Za-z0-9_])NFR\\d+(?![A-Za-z0-9_])", "唯一；需求池 §C"],
    ["需求", "(?<![A-Za-z0-9_])R\\d+(?![A-Za-z0-9_-])", "需求编号；R\\d+-AC 由更长形先取"],
    ["任务", "(?<![A-Za-z0-9_])T\\d+(?:\\.\\d+)?(?![A-Za-z0-9_.])", "任务卡号槽位：预设 T<n>.<m>；项目自有卡号不同则同步改 def_forms.任务"],
    ["里程碑", "(?<![A-Za-z0-9_])M\\d+(?![A-Za-z0-9_])", "ROADMAP Milestone（多位数兼容）"],
    ["设计问题", "(?<![A-Za-z0-9_])Q\\d+(?![A-Za-z0-9_])", "设计文档开放问题"]
  ],
  "id_occ_kinds": {
    "需求AC": "需求AC",
    "任务": "任务",
    "非功能需求": "非功能需求"
  },
  "cooccur_kinds": ["需求AC", "任务", "非功能需求", "需求"],
  "ac_prefix_kinds": {"R": "需求AC"},
  "task_columns": {"spec": "规格锚", "prereq": "前置", "red": "失败先行测试", "status": "状态"},
  "edges": {
    "directed_pairs": [["上游", "下游"]],
    "self_words": ["本文", "本节", "本表", "上文", "下文", "详见", "见"],
    "section_ref_marker": "§",
    "nonlink_prefixes": ["外部：", "泛指："]
  },
  "required_edges": [
    {"rule": "覆盖-AC须有任务卡声明", "src_kinds": ["需求AC"], "edge": "任务声明", "direction": "in", "dst_kinds": ["任务"], "severity": "report"}
  ],
  "nature_source": {
    "field": "类型",
    "map": {
      "结论型": "规范",
      "目标": "规范",
      "目标文档": "规范",
      "需求文档": "规范",
      "设计文档": "规范",
      "接口契约": "规范",
      "契约": "规范",
      "ROADMAP": "规范",
      "决议记录": "规范",
      "核对单": "规范",
      "模板": "规范",
      "任务文档": "规范",
      "过程型": "记述",
      "调研": "记述",
      "复盘": "记述",
      "交接 handoff": "记述",
      "交接handoff": "记述",
      "跨轨登记册": "记述",
      "分配账本": "记述"
    },
    "normalize": "bracket-base"
  }
}
