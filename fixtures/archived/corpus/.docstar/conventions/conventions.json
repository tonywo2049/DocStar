{
 "version": "1",
 "namespaces": {
  "prefix_namespaces": {},
  "kind_namespace": {},
  "req_doc": "requirements.md",
  "param_registry": "parameters.md",
  "task_doc_stem": "tasks",
  "mapping_doc_stem": "mapping"
 },
 "def_forms": {},
 "term_forms": {
  "inplace": "\\*\\*([^*]{2,40})\\*\\*\\s*[（(]\\s*(?:定义|def)\\s*[:：]\\s*([^）)]+)\\s*[）)]",
  "glossary": "^-?\\s*\\*\\*([^*]{2,40})\\*\\*\\s*[:：](.{4,})"
 },
 "form_headers": {
  "ledger": "^\\|\\s*(?:date|日期)\\s*\\|\\s*(?:change|变更)\\s*\\|",
  "changelist": "^\\|\\s*(?:item|项)\\s*\\|\\s*(?:location|落点|文档与落点)\\b",
  "glossary_section": "(?i)术语表|名词解释|词汇表|glossary"
 },
 "harvest": {
  "len_range": [
   2,
   40
  ],
  "exclude": [
   "^\\d+$",
   "^\\d{4}-\\d{2}-\\d{2}$",
   "^v?\\d+(?:\\.\\d+)+[a-z]?$"
  ]
 },
 "edges": {
  "directed_pairs": [
   [
    "上游",
    "下游"
   ]
  ]
 },
 "archive_globs": [
  "Archive"
 ],
 "doc_id_kinds": [
  [
   "归档条目",
   "(?<![A-Za-z0-9_])AR\\d+(?![A-Za-z0-9_])",
   "fixture：归档件内定义、活文档引用的条目（EG-30 id 索引可达性面）"
  ]
 ]
}
