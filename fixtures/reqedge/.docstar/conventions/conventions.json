{
  "version": "1",
  "namespaces": {
    "prefix_namespaces": {},
    "kind_namespace": {},
    "req_doc": "requirements.md",
    "param_registry": "parameters.md",
    "task_doc_stem": "tasks",
    "mapping_doc_stem": "mapping"
  },
  "def_forms": {
    "需求AC": "^-\\s*\\*\\*(REQ-\\d+)\\*\\*",
    "参数": "^\\|\\s*`([A-Za-z_][A-Za-z0-9_]*)`[^|]*\\|",
    "任务": "^\\|\\s*\\*\\*(TASK-\\d+)\\*\\*"
  },
  "term_forms": {
    "inplace": "\\*\\*([^*]{2,40})\\*\\*\\s*[（(]\\s*(?:定义|def)\\s*[:：]\\s*([^）)]+)\\s*[）)]",
    "glossary": "^-?\\s*\\*\\*([^*]{2,40})\\*\\*\\s*[:：](.{4,})"
  },
  "form_headers": {
    "ledger": "^\\|\\s*(?:date|日期)\\s*\\|\\s*(?:change|变更)\\s*\\|",
    "changelist": "^\\|\\s*(?:item|项)\\s*\\|\\s*(?:location|落点|文档与落点)\\b",
    "glossary_section": "(?i)术语表|名词解释|词汇表|glossary"
  },
  "harvest": {
    "len_range": [2, 40],
    "exclude": ["^\\d+$", "^\\d{4}-\\d{2}-\\d{2}$", "^v?\\d+(?:\\.\\d+)+[a-z]?$"]
  },
  "type_sections": [
    ["需求", "^需求$"],
    ["Requirements", "(?i)^requirements$"]
  ],
  "required_edges": [
    {"rule": "覆盖-需求须有验证", "src_kinds": ["需求"], "edge": "验证声明", "direction": "in", "dst_kinds": ["测试"], "severity": "report"}
  ]
}
